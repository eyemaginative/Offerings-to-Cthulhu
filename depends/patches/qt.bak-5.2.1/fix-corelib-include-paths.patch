diff --git a/qtbase/src/corelib/corelib.pro b/qtbase/src/corelib/corelib.pro
--- a/qtbase/src/corelib/corelib.pro
+++ b/qtbase/src/corelib/corelib.pro
@@ -24,6 +24,15 @@ win32-g++*:QMAKE_CXXFLAGS_CXX11 = -std=gnu++0x
 
 load(qt_module)
 
+# Qt 5.2.1 can fail to propagate the generated module include dirs for the
+# module currently being built on modern host toolchains. Add them explicitly
+# so QtCore's own forwarded headers and module-prefixed includes resolve
+# during the target build.
+INCLUDEPATH += ../../include \
+               ../../include/QtCore \
+               ../../include/QtCore/$$QT_VERSION \
+               ../../include/QtCore/$$QT_VERSION/QtCore
+
 include(animation/animation.pri)
 include(arch/arch.pri)
 include(global/global.pri)
