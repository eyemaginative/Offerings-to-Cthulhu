--- a/qtbase/mkspecs/features/qt_module.prf
+++ b/qtbase/mkspecs/features/qt_module.prf
@@ -61 +61,24 @@ load(qt_module_pris)
-INCLUDEPATH *= $$eval(QT.$${MODULE}.includes) $$eval(QT.$${MODULE}_private.includes)
+# Qt 5.2.1 can lose parts of the public/private module include lists on
+# modern qmake runs when the current module and its dependencies are loaded
+# recursively. Reconstruct the full include path set explicitly so every
+# module sees:
+# - the shared include root
+# - the module public root
+# - the versioned include root
+# - the versioned private include root
+MODULE_INCLUDEPATH = $$eval(QT.$${MODULE}.includes)
+MODULE_INCLUDEPATH += $$eval(QT.$${MODULE}_private.includes)
+MODULE_INCLUDEPATH += ../../include
+MODULE_INCLUDEPATH += ../../include/$$MODULE_INCNAME
+MODULE_INCLUDEPATH += ../../include/$$MODULE_INCNAME/$$VERSION
+MODULE_INCLUDEPATH += ../../include/$$MODULE_INCNAME/$$VERSION/$$MODULE_INCNAME
+MODULE_BUILD_DEPENDS = $$replace(QT, -private$, _private)
+MODULE_BUILD_DEPENDS += $$replace(QT_PRIVATE, -private$, _private)
+MODULE_BUILD_DEPENDS = $$resolve_depends($$unique(MODULE_BUILD_DEPENDS), "QT.")
+for(dep, MODULE_BUILD_DEPENDS) {
+    MODULE_INCLUDEPATH += $$eval(QT.$${dep}.includes)
+    MODULE_INCLUDEPATH += $$eval(QT.$${dep}_private.includes)
+}
+MODULE_INCLUDEPATH = $$unique(MODULE_INCLUDEPATH)
+MODULE_INCLUDEPATH -= $$QMAKE_DEFAULT_INCDIRS
+INCLUDEPATH *= $$MODULE_INCLUDEPATH
+export(MODULE_INCLUDEPATH)
+export(MODULE_BUILD_DEPENDS)
 
