--- a/qtbase/mkspecs/features/exclusive_builds_post.prf
+++ b/qtbase/mkspecs/features/exclusive_builds_post.prf
@@ -22,9 +22,17 @@
         # builds associated with that build as the list of existing builds. This
         # partitions the permutations into one set of exclusive builds + the rest
         # of the unknown permutations.
+        currentBuild = $$first(permutationBuilds)
         newExistingBuilds = $$eval($$first(permutationBuilds).exclusive)
         permutationBuilds -= $$newExistingBuilds
 
+        # Modern qmake runs can re-enter this helper with partially initialized
+        # exclusive-build metadata. Ensure the current build is always consumed so
+        # the recursion makes progress instead of looping forever.
+        isEmpty(newExistingBuilds)|!contains(newExistingBuilds, $$currentBuild): \
+            newExistingBuilds += $$currentBuild
+        permutationBuilds -= $$currentBuild
+
         # Recursively compute the combination of these two sets
         recursiveCombination = $$combineExclusiveBuilds($$permutationBuilds, $$newExistingBuilds)
 
