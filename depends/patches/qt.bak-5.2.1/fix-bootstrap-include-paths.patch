diff --git a/qtbase/src/tools/bootstrap/bootstrap.pro b/qtbase/src/tools/bootstrap/bootstrap.pro
--- a/qtbase/src/tools/bootstrap/bootstrap.pro
+++ b/qtbase/src/tools/bootstrap/bootstrap.pro
@@ -50,6 +50,19 @@
 
 load(qt_module)
 
+# Qt 5.2.1 can drop these include paths when bootstrapping on modern hosts.
+# Add them explicitly so forwarded QtCore/QtXml headers, module-prefixed
+# includes such as <QtCore/qtextcodec.h>, and private headers all resolve
+# during the host bootstrap library build.
+INCLUDEPATH += \
+    ../../../include \
+    ../../../include/QtCore \
+    ../../../include/QtCore/$$QT_VERSION \
+    ../../../include/QtCore/$$QT_VERSION/QtCore \
+    ../../../include/QtXml \
+    ../../../include/QtXml/$$QT_VERSION \
+    ../../../include/QtXml/$$QT_VERSION/QtXml
+
 SOURCES += \
            ../../corelib/codecs/qlatincodec.cpp \
            ../../corelib/codecs/qtextcodec.cpp \
