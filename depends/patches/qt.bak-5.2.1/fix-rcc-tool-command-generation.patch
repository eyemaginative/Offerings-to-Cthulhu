--- a/qtbase/mkspecs/features/resources.prf
+++ b/qtbase/mkspecs/features/resources.prf
@@ -1,4 +1,17 @@
 qtPrepareTool(QMAKE_RCC, rcc, _DEP)
+# Match the moc fallback above for rcc so generated resource rules keep a real
+# command body instead of degrading to a no-op.
+isEmpty(QMAKE_RCC) {
+    !isEmpty(QT_TOOL.rcc.binary):QMAKE_RCC = $$shell_path($$eval(QT_TOOL.rcc.binary))
+    else:QMAKE_RCC = $$shell_path($$[QT_HOST_BINS]/rcc)
+}
+isEmpty(QMAKE_RCC_DEP) {
+    !isEmpty(QT_TOOL.rcc.binary):QMAKE_RCC_DEP = $$system_path($$eval(QT_TOOL.rcc.binary))
+    else:QMAKE_RCC_DEP = $$system_path($$[QT_HOST_BINS]/rcc)
+}
+export(QMAKE_RCC)
+export(QMAKE_RCC_DEP)
+
 
 isEmpty(RCC_DIR):RCC_DIR = .
 isEmpty(QMAKE_MOD_RCC):QMAKE_MOD_RCC = qrc
@@ -24,5 +37,5 @@
 rcc.input = RESOURCES
 rcc.variable_out = SOURCES
 rcc.name = RCC ${QMAKE_FILE_IN}
-silent:rcc.commands = @echo rcc ${QMAKE_FILE_IN} && $$rcc.commands
+silent:rcc.commands = $$QMAKE_RCC $$QMAKE_RESOURCE_FLAGS ${QMAKE_FILE_IN} -o ${QMAKE_FILE_OUT}
 QMAKE_EXTRA_COMPILERS += rcc
