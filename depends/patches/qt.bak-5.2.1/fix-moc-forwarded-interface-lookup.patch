diff --git a/qtbase/src/tools/moc/moc.cpp b/qtbase/src/tools/moc/moc.cpp
--- a/qtbase/src/tools/moc/moc.cpp
+++ b/qtbase/src/tools/moc/moc.cpp
@@ -1319,10 +1319,17 @@ void Moc::parseInterfaces(ClassDef *def)
         }
         // resolve from classnames to interface ids
         for (int i = 0; i < iface.count(); ++i) {
-            const QByteArray iid = interface2IdMap.value(iface.at(i).className);
+            QByteArray iid = interface2IdMap.value(iface.at(i).className);
+            if (iid.isEmpty() && !iface.at(i).className.contains("::")
+                    && iface.at(i).className.startsWith('Q')) {
+                // Qt 5.2's moc can miss Q_DECLARE_INTERFACE registrations when the
+                // interface header is reached through a generated forwarding header.
+                iid = "\"org.qt-project.Qt." + iface.at(i).className + "\"";
+                interface2IdMap.insert(iface.at(i).className, iid);
+            }
             if (iid.isEmpty())
                 error("Undefined interface");
 
             iface[i].interfaceId = iid;
         }
        def->interfaceList += iface;
