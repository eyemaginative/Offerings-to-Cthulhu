--- a/qtbase/mkspecs/features/uic.prf
+++ b/qtbase/mkspecs/features/uic.prf
@@ -1,4 +1,17 @@
 qtPrepareTool(QMAKE_UIC, uic, _DEP)
+# Qt 5.2.1 can also drop uic command expansion in generated extra compiler
+# rules. Keep the command explicit by falling back to qt_tool_uic.pri.
+isEmpty(QMAKE_UIC) {
+    !isEmpty(QT_TOOL.uic.binary):QMAKE_UIC = $$shell_path($$eval(QT_TOOL.uic.binary))
+    else:QMAKE_UIC = $$shell_path($$[QT_HOST_BINS]/uic)
+}
+isEmpty(QMAKE_UIC_DEP) {
+    !isEmpty(QT_TOOL.uic.binary):QMAKE_UIC_DEP = $$system_path($$eval(QT_TOOL.uic.binary))
+    else:QMAKE_UIC_DEP = $$system_path($$[QT_HOST_BINS]/uic)
+}
+export(QMAKE_UIC)
+export(QMAKE_UIC_DEP)
+
 
 isEmpty(UI_DIR):UI_DIR = .
 isEmpty(QMAKE_MOD_UIC):QMAKE_MOD_UIC = ui_
@@ -10,7 +23,7 @@
 uic.variable_out = GENERATED_FILES
 uic.CONFIG += no_link target_predeps
 uic.name = UIC ${QMAKE_FILE_IN}
-silent:uic.commands = @echo uic ${QMAKE_FILE_IN} && $$uic.commands
+silent:uic.commands = $$QMAKE_UIC ${QMAKE_FILE_IN} -o ${QMAKE_FILE_OUT}
 QMAKE_EXTRA_COMPILERS += uic
 INCREDIBUILD_XGE += uic
 
