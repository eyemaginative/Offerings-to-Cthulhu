# config.site for OFF cross-compile
# Generated by depends/Makefile — do not edit by hand.
# Source: depends/config.site.in

# Cross-compile toolchain
CC=@CC@
CXX=@CXX@
AR=@AR@
RANLIB=@RANLIB@
NM=@NM@
STRIP=@STRIP@

# Sysroot / prefix
PREFIX=@STAGING_DIR_HOST@
PKG_CONFIG_LIBDIR="$PREFIX/lib/pkgconfig"
PKG_CONFIG_PATH="$PREFIX/lib/pkgconfig"

# Tell autoconf/automake where to find things
ac_default_prefix="$PREFIX"
export CPPFLAGS="-I$PREFIX/include $CPPFLAGS"
export LDFLAGS="-L$PREFIX/lib $LDFLAGS"

# Boost: depends/ builds as static, so tell the AX_BOOST macros where it is
BOOST_ROOT="$PREFIX"
BOOST_INCLUDEDIR="$PREFIX/include"
BOOST_LIBRARYDIR="$PREFIX/lib"

# Override pkg-config to only see our staging area
export PKG_CONFIG_LIBDIR
export PKG_CONFIG_PATH
unset PKG_CONFIG_ALLOW_SYSTEM_CFLAGS
unset PKG_CONFIG_ALLOW_SYSTEM_LIBS

# Disable system library probing for reproducibility
ac_cv_have_decl_strtof=yes

# Qt5 paths (set when Qt is built via depends/)
QT_BIN_PATH="$PREFIX/native/bin"
